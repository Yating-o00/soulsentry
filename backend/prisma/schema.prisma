generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum NoteStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum CreditTransactionType {
  PURCHASE
  CONSUME
  GIFT
  REFUND
  SUBSCRIPTION_BONUS
}

model User {
  id                String                @id @default(cuid())
  email             String                @unique
  passwordHash      String
  displayName       String?
  role              UserRole              @default(USER)
  subscriptionPlan  String                @default("free")
  aiCredits         Int                   @default(200)
  themePreferences  Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  tasks             Task[]
  notes             Note[]
  preferences       UserPreference?
  notifications     Notification[]
  creditTxs         AICreditTransaction[]
  taskExecutions    TaskExecution[]
  dailyPlans        DailyPlan[]
  comments          Comment[]
  taskCompletions   TaskCompletion[]
  taskChangeLogs    TaskChangeLog[]
}

model UserPreference {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  quietHoursStart         String?
  quietHoursEnd           String?
  emailNotifications      Boolean  @default(true)
  pushNotifications       Boolean  @default(true)
  locationReminders       Boolean  @default(false)
  locale                  String   @default("zh-CN")
  timezone                String   @default("Asia/Shanghai")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  title             String
  description       String?
  status            TaskStatus   @default(TODO)
  priority          String       @default("medium")
  category          String?
  dueAt             DateTime?
  reminderTime      DateTime?
  endTime           DateTime?
  isAllDay          Boolean      @default(false)
  parentTaskId      String?
  gcalSyncEnabled   Boolean      @default(false)
  progress          Int          @default(0)
  completedAt       DateTime?
  deletedAt         DateTime?
  tags              Json?
  reminderStrategy  Json?
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, dueAt])
  @@index([userId, reminderTime])
  @@index([userId, deletedAt])
}

model Note {
  id          String     @id @default(cuid())
  userId      String
  title       String?
  content     String
  plainText   String?
  status      NoteStatus @default(ACTIVE)
  color       String?
  sourceType  String?
  aiStatus    String?
  deletedAt   DateTime?
  tags        Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, deletedAt])
}

model Notification {
  id          String             @id @default(cuid())
  userId      String
  title       String
  body        String
  channel     String             @default("in_app")
  status      NotificationStatus @default(PENDING)
  payload     Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AICreditTransaction {
  id            String                @id @default(cuid())
  userId        String
  type          CreditTransactionType
  amount        Int
  balanceAfter  Int
  feature       String?
  description   String?
  createdAt     DateTime              @default(now())
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TaskExecution {
  id               String   @id @default(cuid())
  userId           String
  taskId           String?
  taskTitle        String
  category         String   @default("task")
  executionStatus  String   @default("parsing")
  originalInput    String?
  aiParsedResult   Json?
  executionSteps   Json?
  errorMessage     String?
  completedAt      DateTime?
  automationType   String   @default("none")
  automationPlan   Json?
  automationResult Json?
  requiresApproval Boolean  @default(false)
  userFeedback     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, taskId])
  @@index([userId, executionStatus])
  @@index([userId, completedAt])
}

model DailyPlan {
  id            String   @id @default(cuid())
  userId        String
  planDate      String
  originalInput String?
  theme         String?
  summary       String?
  planJson      Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, planDate])
  @@index([userId, isActive])
  @@index([userId, createdAt])
  @@index([userId, updatedAt])
}

model Comment {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  content     String
  mentions    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([taskId, createdAt])
}

model TaskCompletion {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  status      String   @default("completed")
  completedAt DateTime?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([taskId, createdAt])
  @@index([taskId, completedAt])
}

model TaskChangeLog {
  id            String   @id @default(cuid())
  userId        String
  taskId        String
  parentTaskId  String?
  changeType    String
  taskTitle     String?
  changedFields Json?
  changesDetail Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([taskId, createdAt])
  @@index([parentTaskId, createdAt])
}
