    {
      "function_name": "agentSendEmail",
      "description": "\u4ee3\u7528\u6237\u53d1\u9001\u90ae\u4ef6\u3002\u53c2\u6570: to(\u90ae\u7bb1)\u3001subject(\u53ef\u9009\u4e3b\u9898)\u3001body(\u6b63\u6587)\u3001instruction(\u7528\u6237\u539f\u59cb\u6307\u4ee4)\u3002\u51fd\u6570\u4f1a\u81ea\u52a8\u901a\u8fc7 Gmail \u53d1\u9001\u3001\u5728 Task \u4e2d\u8bb0\u5f55\u4e3a\u5df2\u5b8c\u6210\u3001\u5e76\u5411\u7528\u6237\u521b\u5efa Notification \u544a\u77e5\u3002"
    },
    {
      "function_name": "kimiWebBrowse",
      "description": "\u8054\u7f51\u68c0\u7d22\u5de5\u5177\u3002\u53c2\u6570\uff1aquery(\u8981\u67e5\u8be2\u7684\u95ee\u9898)\u3001language(\u53ef\u9009 zh/en)\u3002\u8c03\u7528\u540e\u8fd4\u56de answer + references(\u53c2\u8003\u7f51\u5740)\u3002\u9002\u7528\u4e8e\u9700\u8981\u5b9e\u65f6/\u7f51\u7edc\u4fe1\u606f\u7684\u95ee\u9898\uff1a\u5929\u6c14\u3001\u65b0\u95fb\u3001\u80a1\u7968\u3001\u4ef7\u683c\u3001\u5b9e\u65f6\u4e8b\u4ef6\u3001\u516c\u53f8\u8d44\u6599\u7b49\u3002"
    },
    {
      "function_name": "agentFileManager",
      "description": "\u6587\u4ef6\u7ba1\u7406\u5de5\u5177\u3002\u53c2\u6570 op \u53ef\u4ee5\u662f:\n- \"upload\": \u4e0a\u4f20\u6587\u4ef6\u3002\u9700\u8981 file_name + (content_base64 \u6216 source_url)\uff0c\u53ef\u9009 mime_type\u3002\u8fd4\u56de file_url\u3002\n- \"list\": \u5217\u51fa\u7528\u6237\u6240\u6709\u4e0a\u4f20\u8fc7\u7684\u9644\u4ef6\u3002\u53ef\u9009 limit\u3002\n- \"download\": \u8fd4\u56de\u6587\u4ef6\u7684\u4e0b\u8f7d URL\u3002\u9700\u8981 file_url\u3002\n\u4e0a\u4f20\u6210\u529f\u540e\uff0c\u628a\u8fd4\u56de\u7684 file_url \u53d1\u7ed9\u7528\u6237\u5373\u53ef\u4e0b\u8f7d\u3002"
    }
  ],
