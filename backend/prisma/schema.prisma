model UserPreference {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  quietHoursStart         String?
  quietHoursEnd           String?
  emailNotifications      Boolean  @default(true)
  pushNotifications       Boolean  @default(true)
  locationReminders       Boolean  @default(false)
  locale                  String   @default("zh-CN")
  timezone                String   @default("Asia/Shanghai")
  metadata                Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  title             String
  description       String?
  status            TaskStatus   @default(TODO)
  priority          String       @default("medium")
  category          String?
  dueAt             DateTime?
  reminderTime      DateTime?
  endTime           DateTime?
  isAllDay          Boolean      @default(false)
  parentTaskId      String?
  gcalSyncEnabled   Boolean      @default(false)
  progress          Int          @default(0)
  completedAt       DateTime?
  deletedAt         DateTime?
  tags              Json?
  reminderStrategy  Json?
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, dueAt])
  @@index([userId, reminderTime])
  @@index([userId, deletedAt])
}

model Note {
  id          String     @id @default(cuid())
  userId      String
  title       String?
  content     String
  plainText   String?
  status      NoteStatus @default(ACTIVE)
  color       String?
  sourceType  String?
  aiStatus    String?
  deletedAt   DateTime?
  tags        Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteComments NoteComment[]

  @@index([userId, status])
  @@index([userId, deletedAt])
}

model Notification {
  id          String             @id @default(cuid())
  userId      String
  title       String
  body        String
  channel     String             @default("in_app")
  status      NotificationStatus @default(PENDING)
  payload     Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model NotificationRule {
  id                String   @id @default(cuid())
  userId            String
  title             String
  conditionCategory String   @default("all")
  conditionPriority String   @default("all")
  actionMute        Boolean  @default(false)
  actionSound       String   @default("default")
  actionChannels    Json?
  isEnabled         Boolean  @default(true)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isEnabled])
}

model SavedLocation {
  id                String   @id @default(cuid())
  userId            String
  name              String
  locationType      String   @default("other")
  latitude          Float
  longitude         Float
  radius            Int      @default(200)
  address           String?
  icon              String   @default("📍")
  isActive          Boolean  @default(true)
  triggerOn         String   @default("enter")
  lastEnteredAt     DateTime?
  lastExitedAt      DateTime?
  quietMinutes      Int      @default(30)
  quietPolicy       Json?
  notificationStats Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([userId, isActive])
  @@index([userId, locationType])
}

model Relationship {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  nickname             String?
  relationshipType     String   @default("friend")
  closeness            Int      @default(5)
  interactionCount     Int      @default(0)
  lastInteractionDate  DateTime?
  favors               Json?
  notes                String?
  tags                 Json?
  preferredContactTime String?
  contactFrequencyDays Int      @default(30)
  avatarColor          String   @default("#384877")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([userId, relationshipType])
  @@index([userId, lastInteractionDate])
}

model UserBehavior {
  id                  String   @id @default(cuid())
  userId              String
  eventType           String
  taskId              String?
  hourOfDay           Int?
  dayOfWeek           Int?
  category            String?
  responseTimeSeconds Int?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, eventType])
  @@index([userId, taskId])
}

model MemoryRecord {
  id           String   @id @default(cuid())
  userId       String
  title        String
  content      String?
  memoryType   String   @default("personal")
  emotion      String   @default("neutral")
  eventDate    DateTime?
  people       Json?
  locations    Json?
  tags         Json?
  aiInsight    Json?
  sourceTaskId String?
  sourceNoteId String?
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([userId, memoryType])
  @@index([userId, eventDate])
}

model KnowledgeBase {
  id               String   @id @default(cuid())
  userId           String
  title            String
  content          String
  sourceType       String   @default("manual")
  sourceId         String?
  tags             Json?
  category         String?
  summary          String?
  keyPoints        Json?
  embeddings       Json?
  accessCount      Int      @default(0)
  lastAccessed     DateTime?
  importance       Int      @default(3)
  embeddingSummary String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([userId, sourceType])
  @@index([userId, category])
  @@index([userId, importance])
}

model ExternalFeed {
  id                     String   @id @default(cuid())
  userId                 String
  name                   String
  feedType               String   @default("rss")
  url                    String?
  description            String?
  icon                   String   @default("📡")
  isActive               Boolean  @default(true)
  fetchFrequencyHours    Int      @default(24)
  lastFetchedAt          DateTime?
  lastItemCount          Int      @default(0)
  autoArchiveToHeartsign Boolean  @default(true)
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([userId, isActive])
  @@index([userId, feedType])
}

model AICreditTransaction {
  id            String                @id @default(cuid())
  userId        String
  type          CreditTransactionType
  amount        Int
  balanceAfter  Int
  feature       String?
  description   String?
  createdAt     DateTime              @default(now())
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TaskExecution {
  id               String   @id @default(cuid())
  userId           String
  taskId           String?
  taskTitle        String
  category         String   @default("task")
  executionStatus  String   @default("parsing")
  originalInput    String?
  aiParsedResult   Json?
  executionSteps   Json?
  errorMessage     String?
  completedAt      DateTime?
  automationType   String   @default("none")
  automationPlan   Json?
  automationResult Json?
  requiresApproval Boolean  @default(false)
  userFeedback     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, taskId])
  @@index([userId, executionStatus])
  @@index([userId, completedAt])
}

